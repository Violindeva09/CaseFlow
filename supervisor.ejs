<!DOCTYPE html>
<html>
<head>
  <title>Supervisor Dashboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/style.css" rel="stylesheet">
</head>
<body>
  <div class="container mt-4">
    <!-- Header with Logout -->
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h2 class="text-white fw-bold">Supervisor Dashboard</h2>
      <a href="/" class="btn btn-logout">Logout</a>
    </div>

    <!-- Tickets Table -->
    <div class="card shadow p-4">
      <h4 class="mb-3 text-primary">Escalated Tickets</h4>
      <table class="table table-bordered table-striped">
        <thead class="table-dark">
          <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Urgency</th>
            <th>Status</th>
            <th>SLA</th>
          </tr>
        </thead>
        <tbody>
          <% if (tickets.length === 0) { %>
            <tr><td colspan="5" class="text-center">No escalated tickets</td></tr>
          <% } else { %>
            <% tickets.forEach(ticket => { %>
              <tr>
                <td><%= ticket.id %></td>
                <td><%= ticket.title %></td>
                <td>
                  <% if (ticket.urgency === "Critical") { %>
                    <span class="badge bg-danger"><%= ticket.urgency %></span>
                  <% } else if (ticket.urgency === "High") { %>
                    <span class="badge bg-warning text-dark"><%= ticket.urgency %></span>
                  <% } else { %>
                    <span class="badge bg-success"><%= ticket.urgency %></span>
                  <% } %>
                </td>
                <td>
                  <% if (ticket.status === "Resolved") { %>
                    <span class="badge bg-success">Resolved</span>
                  <% } else { %>
                    <span class="badge bg-secondary"><%= ticket.status %></span>
                  <% } %>
                </td>
                <td>
                  <% if (ticket.sla === "Breached") { %>
                    <span class="badge bg-danger">Breached</span>
                  <% } else if (ticket.sla === "At Risk") { %>
                    <span class="badge bg-warning text-dark">At Risk</span>
                  <% } else { %>
                    <span class="badge bg-success">Safe</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>